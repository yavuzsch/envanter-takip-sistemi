{
  "name": "inventory-app",
  "version": "1.0.0",
  "description": "Envanter Takip Sistemi",
  "main": "server.ts",
  "scripts": {
    "dev": "tsx watch server.ts",
    "build": "tsc -p tsconfig.server.json",
    "start": "node dist/server.js",
    "test": "vitest run",
